# Copy to .env.local for local configuration. Never commit populated env files.
# The PostHog values below are safe to expose client-side (NEXT_PUBLIC_*). The
# "project API key" is a publishable, write-only key, not a secret.
#
# When NEXT_PUBLIC_POSTHOG_KEY is unset (local dev, CI, opt-out), the
# analytics layer is a hard no-op: nothing loads and the build still passes.
# See docs/ANALYTICS.md for what is tracked.

# PostHog project API key (publishable client key)
NEXT_PUBLIC_POSTHOG_KEY=

# PostHog API host (default: https://us.i.posthog.com; use https://eu.i.posthog.com for EU)
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- OpenAdapt Hosted - Stripe Checkout -------------------------------------
# The website creates Checkout Sessions. OpenAdapt Cloud retrieves and claims
# those Sessions and owns the signed Stripe webhook and subscription state.
# Web and Cloud must use the same Stripe account, mode, and recurring price.
#
# Production: STRIPE_EXPECTED_MODE=live, an sk_live_ key, the matching live
# recurring price, and the exact production site and Cloud origins below.
# Test/preview: use STRIPE_EXPECTED_MODE=test, an sk_test_ key, the matching
# test price, and exact HTTPS origins for that environment. If any required
# value is absent or mismatched, the offer is unavailable and checkout returns
# HTTP 503. There is no request-host or concierge checkout fallback.
# See docs/HOSTED_PHASE0.md.

# Stripe secret key (server-side): sk_live_... in production.
STRIPE_SECRET_KEY=

# Matching recurring price created in the same Stripe account and mode.
STRIPE_PRICE_ID=

# Refuse a key from the wrong Stripe mode. Use "test" outside production.
STRIPE_EXPECTED_MODE=live

# Exact canonical site origin used for Checkout cancellation URLs.
NEXT_PUBLIC_SITE_URL=https://openadapt.ai

# --- OpenAdapt Cloud app (self-serve funnel) --------------------------------
# Exact Cloud origin. Successful checkout routes to /login with only the opaque
# Checkout Session id; Cloud verifies it before linking an organization.
NEXT_PUBLIC_CLOUD_APP_URL=https://app.openadapt.ai
